DATABASE_URL="postgresql://postgres:postgres@localhost:5432/click_intern_core?schema=public"

# JWT secrets MUST be at least 32 chars. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-me-with-32+char-random-access-secret-please"
JWT_REFRESH_SECRET="replace-me-with-32+char-random-refresh-secret-please"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3000
NODE_ENV="development"

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS="http://localhost:5173"

# Set to true behind HTTPS in production
COOKIE_SECURE=false

# Throttling
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_MS=60000
AUTH_THROTTLE_LIMIT=10

# Uploads
UPLOAD_MAX_SIZE_BYTES=5242880

# Frontend
VITE_API_URL="http://localhost:3000"
