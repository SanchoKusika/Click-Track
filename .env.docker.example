# Copy this file to .env.docker and fill in real values before running docker compose.
# Never commit the resulting .env.docker file.

# Postgres credentials used by the postgres service AND embedded into DATABASE_URL below.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me-with-strong-postgres-password
POSTGRES_DB=click_intern_core

# Backend
DATABASE_URL=postgresql://postgres:replace-me-with-strong-postgres-password@postgres:5432/click_intern_core?schema=public
NODE_ENV=production
PORT=3000

# JWT secrets MUST be at least 32 chars. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-32+char-random-access-secret-please
JWT_REFRESH_SECRET=replace-me-with-32+char-random-refresh-secret-please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# IMPORTANT: keep this `false` while you serve over plain http://localhost.
# Browsers silently drop Set-Cookie with Secure flag over http, breaking refresh.
# Switch to `true` only behind HTTPS in production.
COOKIE_SECURE=false

# Throttling
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
AUTH_THROTTLE_TTL_MS=60000
# 10 is good for prod brute-force protection; raise to 30-50 in dev.
AUTH_THROTTLE_LIMIT=30

# Uploads
UPLOAD_MAX_SIZE_BYTES=5242880

# Frontend build-time API URL
VITE_API_URL=http://localhost:3000
