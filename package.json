{
  "name": "click-intern-core",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "lint": "npm run lint --workspace backend && npm run lint --workspace frontend",
    "swagger:generate": "npm run swagger:generate --workspace backend",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "backend/**/*.ts": [
      "eslint --fix --no-warn-ignored"
    ],
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier -w"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier -w"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
